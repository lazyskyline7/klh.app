# =============================================================================
# CONTENT SOURCE
# =============================================================================
# Private GitHub repo containing resume data and blog content
# CONTENT_REPO='owner/klh-content'
# CONTENT_GITHUB_TOKEN='ghp_...'
# Resume variant (default, canva, ...)
RESUME_VARIANT='default'

# =============================================================================
# PRINT EMAIL OVERRIDE (optional)
# =============================================================================
# GRAVATAR (optional — profile data on landing page)
# =============================================================================
# SHA256 hash of your Gravatar email
# GRAVATAR_HASH=''
# API token — enables interests
# GRAVATAR_API_TOKEN=''

# =============================================================================
# Shown instead of the data email when printing/exporting to PDF
PRINT_EMAIL=''

# =============================================================================
# THEME PRESET (optional - overrides all colors below)
# =============================================================================
# Options: default, meta, amazon, apple, microsoft, netflix, spotify
NEXT_PUBLIC_THEME_PRESET=''

# =============================================================================
# PRIMARY ACCENT COLORS
# =============================================================================
NEXT_PUBLIC_COLOR_PRIMARY_500='139 92 246'
NEXT_PUBLIC_COLOR_PRIMARY_600='124 58 237'
NEXT_PUBLIC_COLOR_PRIMARY_400='167 139 250'

# =============================================================================
# GRADIENT TEXT COLORS (for name/title)
# =============================================================================
NEXT_PUBLIC_GRADIENT_FROM_LIGHT='15 23 42'
NEXT_PUBLIC_GRADIENT_VIA_LIGHT='15 23 42'
NEXT_PUBLIC_GRADIENT_TO_LIGHT='124 58 237'
NEXT_PUBLIC_GRADIENT_FROM_DARK='248 250 252'
NEXT_PUBLIC_GRADIENT_VIA_DARK='248 250 252'
NEXT_PUBLIC_GRADIENT_TO_DARK='167 139 250'

# =============================================================================
# BACKGROUND BLOB COLORS
# =============================================================================
NEXT_PUBLIC_BLOB_COLOR_1='139 92 246'
NEXT_PUBLIC_BLOB_COLOR_2='59 130 246'
NEXT_PUBLIC_BLOB_COLOR_3='217 70 239'
NEXT_PUBLIC_BLOB_COLOR_4='139 92 246'

# =============================================================================
# PRINT MODE COLORS
# =============================================================================
NEXT_PUBLIC_PRINT_ACCENT='79 70 229'
NEXT_PUBLIC_PRINT_TEXT='15 23 42'
